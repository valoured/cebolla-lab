# Cebolla Laboratory — Environment Variables
# Copy this file to .env and fill in your Supabase credentials.
# Never commit the actual .env file.

# From Supabase dashboard: Settings → API
SUPABASE_URL=https://yourproject.supabase.co

# Service role key (full DB access) — used by Python scripts
# DO NOT expose this in the frontend. Use the anon key for frontend.
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Anon/public key — used by the frontend (Cloudflare Pages)
SUPABASE_ANON_KEY=your-anon-key-here
